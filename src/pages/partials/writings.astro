---
export const partial = true;
import WritingCard from '../../components/WritingCard.astro';
import { getCollection } from 'astro:content';

const page = Number(Astro.url.searchParams.get('page')) || 1;
const perPage = 10;
const start = (page - 1) * perPage;
const end = start + perPage;

const allWritings = (await getCollection('writings', ({ data }: any) => !data.draft))
  .sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf());

const writings = allWritings.slice(start, end);
---
{writings.map((post: any) => (
  <WritingCard post={post} />
))}
