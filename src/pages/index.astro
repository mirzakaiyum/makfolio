---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Main content padding -->
  <div class="flex flex-col gap-40">
    
    <!-- Hero Section -->
    <section class="opacity-0 flex flex-col gap-10 items-start">
      <div class="inline-flex items-center rounded-full border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 select-none">
        <span class="text-[11px] px-4.5 py-2.5 font-mono tracking-[0.15em] uppercase text-neutral-600 dark:text-neutral-400 font-medium">Welcome to my portfolio</span>
      </div>
      
      <h1 class="text-5xl md:text-6xl lg:text-[90px] leading-[0.95] tracking-tight text-neutral-900 dark:text-white uppercase">
        Hello! 👋<br>
        I'm Mak
      </h1>
      <p class="text-neutral-600 dark:text-neutral-400 text-lg md:text-[22px] leading-[1.6] max-w-3xl mt-4 font-normal">
        I build scalable systems, digital products, and clean architectures that translate strategy into clear, high-quality engineering outcomes across startups and enterprises.
      </p>
      
      <div class="flex flex-wrap gap-3 mt-4">
        {['FULL-STACK DEVELOPMENT', 'INFRASTRUCTURE', 'PRODUCT ARCHITECTURE'].map((skill) => (
          <span class="px-5 py-2.5 rounded-full border border-neutral-200 dark:border-neutral-800 text-[11px] font-mono tracking-widest uppercase bg-transparent text-neutral-700 dark:text-neutral-300 font-medium select-none">
            {skill}
          </span>
        ))}
      </div>
      

      <div class="flex flex-col sm:flex-row gap-4 mt-6 w-full sm:w-auto">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 rounded-[16px] bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 font-mono text-xs tracking-[0.15em] font-bold uppercase hover:-translate-y-1 hover:shadow-xl hover:shadow-black/10 dark:hover:shadow-white/10 transition-all duration-300">
          BOOK A CHAT
        </a>
        <button class="inline-flex items-center justify-center px-8 py-4 rounded-[16px] border bg-white dark:bg-neutral-900 border-neutral-200 dark:border-neutral-800 font-mono text-xs font-bold tracking-[0.15em] uppercase hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors">
          COPY EMAIL
        </button>
      </div>
    </section>

    <!-- Stats Grid -->
    <section class="opacity-0 grid grid-cols-2 md:grid-cols-4 gap-12 md:gap-8 border-t border-b border-neutral-200 dark:border-neutral-800 py-20 relative">
      <div class="absolute inset-0 bg-linear-to-r from-transparent via-neutral-100/50 dark:via-neutral-800/20 to-transparent pointer-events-none"></div>
      
      {[
        { label: 'Happy Clients', value: '40+' },
        { label: 'Years Experience', value: '5+' },
        { label: 'Products Shipped', value: '50+' },
        { label: 'Problems Solved', value: '∞' }
      ].map((stat, index) => (
        <div class="flex flex-col gap-4 relative z-10">
          <span class="text-5xl md:text-[64px] leading-none font-heading text-neutral-900 dark:text-white group-hover:scale-110 transition-transform origin-left">{stat.value}</span>
          <span class="text-[11px] font-mono text-neutral-500 dark:text-neutral-400 uppercase tracking-widest font-medium">{stat.label}</span>
        </div>
      ))}
    </section>

    <!-- Services / What I work on -->
    <section class="opacity-0 flex flex-col gap-16">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading tracking-tight uppercase">What I Work On</h2>
      <div class="flex flex-col">
        {[
          { title: 'Full-Stack Ecosystems', desc: 'End-to-end architecture, scalable APIs, and responsive front-ends' },
          { title: 'Cloud Infrastructure', desc: 'Deployment strategies, CI/CD pipelines, and serverless architectures' },
          { title: 'Product Engineering', desc: 'Taking ownership from technical concept to executed product delivery' }
        ].map((service, i) => (
          <div class="flex flex-col md:flex-row justify-between items-start md:items-center py-10 border-b border-neutral-200 dark:border-neutral-800 group cursor-pointer">
            <div class="flex flex-col gap-3 max-w-2xl transition-transform duration-300 group-hover:translate-x-2">
              <h3 class="text-2xl md:text-[32px] font-bold tracking-tight text-neutral-900 dark:text-white transition-colors">{service.title}</h3>
              <p class="text-sm font-mono text-neutral-500 dark:text-neutral-400 uppercase tracking-wider">{service.desc}</p>
            </div>
            <div class="hidden md:flex w-14 h-14 rounded-full border border-neutral-300 dark:border-neutral-700 items-center justify-center group-hover:bg-neutral-900 group-hover:border-neutral-900 dark:group-hover:bg-white dark:group-hover:border-white group-hover:-rotate-45 transition-all duration-300 mt-4 md:mt-0">
              <svg class="w-5 h-5 text-neutral-900 dark:text-white group-hover:text-white dark:group-hover:text-neutral-900 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Let's Work Together CTA -->
    <section class="opacity-0 flex flex-col gap-10 bg-neutral-100 dark:bg-[#181818] rounded-[32px] p-10 md:p-16 mb-24 border border-neutral-200/50 dark:border-neutral-800/50 relative overflow-hidden">
      <!-- Decorative background element -->
      <div class="absolute top-0 right-0 p-16 opacity-5 pointer-events-none">
        <svg class="w-96 h-96 text-neutral-900 dark:text-white" fill="currentColor" viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="50"></circle>
        </svg>
      </div>

      <h2 class="text-5xl md:text-[80px] font-heading tracking-tight leading-[0.95] uppercase relative z-10">Let's Work<br>Together!</h2>
      <p class="text-neutral-600 dark:text-neutral-400 text-lg md:text-[20px] max-w-xl leading-[1.6] relative z-10 font-normal">
        If you're building a brand, product, or platform and need a technical partner who can think strategically and execute at a high level - I'd love to connect.
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-4 relative z-10">
        <a href="mailto:hello@mirzakaiyum.com" class="flex flex-col gap-3 p-8 rounded-[20px] bg-white dark:bg-[#202020] shadow-sm hover:shadow-md border border-neutral-200/50 dark:border-neutral-800 hover:border-neutral-300 dark:hover:border-neutral-600 transition-all duration-300 group">
          <span class="text-[10px] font-mono text-neutral-400 uppercase tracking-[0.2em] font-medium">E-mail</span>
          <span class="text-xl md:text-2xl font-bold tracking-tight group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors">hello@mirzakaiyum.com</span>
        </a>
        <a href="#" class="flex flex-col gap-3 p-8 rounded-[20px] bg-white dark:bg-[#202020] shadow-sm hover:shadow-md border border-neutral-200/50 dark:border-neutral-800 hover:border-neutral-300 dark:hover:border-neutral-600 transition-all duration-300 group">
          <span class="text-[10px] font-mono text-neutral-400 uppercase tracking-[0.2em] font-medium">Phone / Whatsapp</span>
          <span class="text-xl md:text-2xl font-bold tracking-tight group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors">+123 456 7890</span>
        </a>
      </div>
      
      <div class="mt-8 flex items-center justify-between border-t border-neutral-200 dark:border-neutral-800 pt-8 relative z-10">
        <span class="text-[10px] font-mono text-neutral-400 uppercase tracking-[0.2em]">Built with <span class="text-red-500">♥</span> By Mak</span>
        <button id="scroll-to-top" class="text-[10px] font-mono text-neutral-500 hover:text-neutral-900 dark:hover:text-white uppercase tracking-[0.2em] transition-colors">Back to top ↑</button>
      </div>
    </section>
    
  </div>

  <script>
    import { animate, inView } from "motion";

    document.getElementById('scroll-to-top')?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // Reveal animations
    inView("section", (element) => {
      animate(element,
        { opacity: [0, 1], y: [40, 0] },
        { duration: 0.8, ease: [0.16, 1, 0.3, 1] }
      );
    }, { margin: "-10% 0px" });
  </script>
</Layout>
