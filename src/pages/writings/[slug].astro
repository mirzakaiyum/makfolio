---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const writings = await getCollection('writings', ({ data }) => !data.draft);
  return writings.map((post) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const post = await getEntry('writings', slug);
if (!post) return Astro.redirect('/writings');

const { Content, headings } = await render(post);
---

<Layout>
  <div class="px-6 py-12 md:px-16 md:py-24 lg:px-24 lg:py-32 max-w-5xl mx-auto flex flex-col gap-10">

    <!-- Back link -->
    <a href="/writings" class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-widest text-neutral-400 dark:text-neutral-500 hover:text-neutral-900 dark:hover:text-white transition-colors w-max group">
      <svg class="w-3.5 h-3.5 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      All Writings
    </a>

    <!-- Header -->
    <header class="flex flex-col gap-5">
      <span class="text-[11px] font-mono text-neutral-400 dark:text-neutral-500 uppercase tracking-widest">
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading tracking-tight text-neutral-900 dark:text-white uppercase leading-[1.05]">
        {post.data.title}
      </h1>
      <p class="text-lg md:text-xl text-neutral-500 dark:text-neutral-400 leading-relaxed">
        {post.data.description}
      </p>
      <div class="flex flex-wrap gap-2">
        {post.data.tags.map((tag) => (
          <span class="px-3 py-1.5 rounded-full border border-neutral-200 dark:border-neutral-700 text-[10px] font-mono uppercase tracking-widest text-neutral-500 dark:text-neutral-400">
            {tag}
          </span>
        ))}
      </div>
    </header>

    <hr class="border-neutral-200 dark:border-neutral-800" />

    <div class="flex flex-col lg:flex-row gap-12 lg:gap-24 items-start w-full">
      <!-- Main Content -->
      <article class="flex-1 min-w-0 prose prose-neutral dark:prose-invert prose-headings:font-sans prose-headings:uppercase prose-headings:tracking-tight prose-a:text-neutral-900 dark:prose-a:text-white prose-code:font-mono max-w-none w-full
        prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6
        prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-4
        prose-h4:text-xl prose-h4:mt-6 prose-h4:mb-4
        prose-h5:text-lg prose-h5:mt-6 prose-h5:mb-4
        prose-h6:text-base prose-h6:mt-6 prose-h6:mb-4">
        <Content />
      </article>

      <!-- TOC Sidebar -->
      {headings.length > 0 && (
        <aside class="hidden lg:flex w-56 shrink-0 flex-col gap-4 sticky top-12">
          <h3 class="text-xs font-mono uppercase tracking-widest text-neutral-400 dark:text-neutral-500 mb-2">Table of Contents</h3>
          <ul class="flex flex-col gap-3 border-l border-neutral-200 dark:border-neutral-800">
            {headings.map(heading => (
              <li>
                <a 
                  href={`#${heading.slug}`} 
                  class={`block text-[13px] text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors py-1 hover:border-l-2 hover:-ml-[1px] hover:border-neutral-900 dark:hover:border-white pl-4 ${heading.depth === 3 ? 'ml-4' : heading.depth > 3 ? 'ml-8' : ''}`}
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}
    </div>

  </div>
</Layout>
