---
export interface Props {
  project: any;
}

const { project } = Astro.props;
---
<a
  href={`/projects/${project.id}`}
  class="group flex flex-col gap-6 p-6 rounded-[24px] border border-neutral-200 dark:border-neutral-800 bg-neutral-50/50 dark:bg-neutral-900/50 hover:bg-white dark:hover:bg-neutral-900 hover:border-neutral-300 dark:hover:border-neutral-700 hover:shadow-lg hover:shadow-black/5 dark:hover:shadow-black/20 hover:-translate-y-1 transition-all duration-300 overflow-hidden"
>
  {/* Thumbnail */}
  <div class="w-full aspect-4/3 rounded-[16px] overflow-hidden bg-neutral-200 dark:bg-neutral-800 relative">
    {project.data.image ? (
      <img src={project.data.image} alt={project.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-neutral-400 dark:text-neutral-600 font-mono text-sm uppercase tracking-widest">No Image</div>
    )}
    {project.data.featured && (
      <div class="absolute top-4 left-4 px-3 py-1.5 rounded-full bg-white/90 dark:bg-neutral-900/90 backdrop-blur-sm shadow-sm text-neutral-900 dark:text-white text-[10px] font-mono uppercase tracking-widest font-bold">
        Featured
      </div>
    )}
  </div>
  
  <div class="flex flex-col gap-3 flex-1 px-1">
    <span class="text-[11px] font-mono text-neutral-400 dark:text-neutral-500 uppercase tracking-widest">
      {project.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
    </span>

    <h2 class="text-2xl md:text-[28px] font-bold tracking-tight text-neutral-900 dark:text-white group-hover:text-neutral-700 dark:group-hover:text-neutral-200 transition-colors line-clamp-1">
      {project.data.title}
    </h2>
    <p class="text-sm md:text-base text-neutral-500 dark:text-neutral-400 leading-relaxed mb-auto line-clamp-2">
      {project.data.description}
    </p>

    <div class="flex flex-wrap gap-2 mt-3">
      {project.data.tags.map((tag: string) => (
        <span class="px-3 py-1 rounded-full border border-neutral-200 dark:border-neutral-700 text-[10px] font-mono uppercase tracking-widest text-neutral-500 dark:text-neutral-400">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
