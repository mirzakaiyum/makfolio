---
<button id="theme-toggle" type="button" class="flex items-center gap-2 px-4 py-2 rounded-full bg-neutral-200/50 dark:bg-neutral-800/50 hover:bg-neutral-200 dark:hover:bg-neutral-800 transition-colors cursor-pointer w-max group" aria-label="Toggle Dark Mode">
  <svg class="w-4 h-4 text-neutral-800 dark:text-neutral-200 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>
  <svg class="w-4 h-4 text-neutral-800 dark:text-neutral-200 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
  <span class="text-xs font-mono font-medium text-neutral-600 dark:text-neutral-400">Theme</span>
</button>

<script>
  // Add listeners to all theme toggles in case there are multiple
  const toggles = document.querySelectorAll("#theme-toggle");
  
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");
    
    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  }
  
  toggles.forEach(toggle => {
    toggle.addEventListener("click", handleToggleClick);
  });
</script>
