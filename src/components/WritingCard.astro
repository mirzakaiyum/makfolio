---
export interface Props {
  post: any;
}

const { post } = Astro.props;
---
<a
  href={post.data.externalUrl || `/writings/${post.id}`}
  target={post.data.externalUrl ? "_blank" : undefined}
  rel={post.data.externalUrl ? "noopener noreferrer" : undefined}
  class="group flex flex-col md:flex-row gap-6 py-8 border-b border-neutral-200 dark:border-neutral-800 first:border-t hover:px-4 transition-all duration-300"
>
  <div class="w-full md:w-56 shrink-0 aspect-video md:aspect-4/3 rounded-[12px] overflow-hidden bg-neutral-100 dark:bg-neutral-800/80 relative">
    {post.data.image ? (
      <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
    ) : (
      <div class="w-full h-full flex items-center justify-center border border-neutral-200 dark:border-neutral-800 rounded-[12px]">
        <svg class="w-6 h-6 text-neutral-300 dark:text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
      </div>
    )}
  </div>

  <div class="flex flex-col justify-center gap-2 max-w-2xl flex-1">
    <div class="flex items-center gap-3">
      {post.data.externalUrl && (
        <span class="inline-flex items-center gap-1.5 px-2.5 pt-[1px] rounded-full bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 text-[10px] font-mono uppercase tracking-widest shadow-sm border border-neutral-200 dark:border-neutral-800 shrink-0 flex-none font-bold">
          {new URL(post.data.externalUrl).hostname.replace('www.', '')}
        </span>
      )}
      <span class="text-[11px] font-mono text-neutral-400 dark:text-neutral-500 uppercase tracking-widest">
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
      </span>
    </div>
    <h2 class="text-xl md:text-2xl font-bold tracking-tight text-neutral-900 dark:text-white group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors">
      {post.data.title}
    </h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">
      {post.data.description}
    </p>
    <div class="flex flex-wrap gap-2 mt-1">
      {post.data.tags.map((tag: string) => (
        <span class="px-3 py-1 rounded-full border border-neutral-200 dark:border-neutral-700 text-[10px] font-mono uppercase tracking-widest text-neutral-500 dark:text-neutral-400">
          {tag}
        </span>
      ))}
    </div>
  </div>

  <!-- Arrow -->
  <div class="hidden md:flex w-10 h-10 shrink-0 rounded-full border border-neutral-300 dark:border-neutral-700 items-center justify-center group-hover:bg-neutral-900 group-hover:border-neutral-900 dark:group-hover:bg-white dark:group-hover:border-white group-hover:-rotate-45 transition-all duration-300 ml-4">
    <svg class="w-3.5 h-3.5 text-neutral-900 dark:text-white group-hover:text-white dark:group-hover:text-neutral-900 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
    </svg>
  </div>
</a>
