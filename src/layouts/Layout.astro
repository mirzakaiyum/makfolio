---
import "@fontsource/inter";
import "@fontsource/spline-sans-mono";
import "@fontsource/gasoek-one";
import "../styles/global.css";

import Sidebar from "../components/Sidebar.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Mak | Full Stack Engineer</title>
    <script is:inline>
      // Font loading logic to prevent FOUT
      document.documentElement.classList.add("fonts-loading");
      if (document.fonts) {
        document.fonts.ready.then(() => {
          document.documentElement.classList.remove("fonts-loading");
        });
      } else {
        document.documentElement.classList.remove("fonts-loading");
      }

      // Theme toggle initialization
      const getThemePreference = () => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      };
      const isDark = getThemePreference() === "dark";
      document.documentElement.classList[isDark ? "add" : "remove"]("dark");
    </script>
  </head>
  <body class="flex flex-col lg:flex-row min-h-screen w-full">
    <Sidebar />
    <main class="flex-1 w-full min-h-screen p-2 lg:p-2 lg:ml-60 relative z-20">
      <!-- Window-in-Window Content Card -->
      <div
        class="w-full min-h-[calc(100vh-3rem)] bg-inner-bg dark:bg-inner-bg-dark lg:rounded-2xl shadow-sm relative border border-neutral-200/50 dark:border-neutral-800/50 overflow-hidden"
      >
        <div class="flex flex-col w-full h-full px-14 py-10">
          <slot />
        </div>
      </div>
    </main>
  </body>
</html>
